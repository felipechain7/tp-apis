# ── Base de datos ─────────────────────────────────────────────────────────────
# MongoDB Atlas → tu cluster → Connect → Drivers → copiar el string
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/comparador?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# String largo y aleatorio. NO reutilizar el password de Mongo.
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

PORT=3000

# ── Mercado Libre (OAuth) ─────────────────────────────────────────────────────
# Crear app en https://developers.mercadolibre.com.ar
ML_APP_ID=tu_app_id
ML_CLIENT_SECRET=tu_client_secret
# Debe coincidir EXACTO con la redirect URI configurada en la app de ML
ML_REDIRECT_URI=http://localhost:3000/api/ml/callback
